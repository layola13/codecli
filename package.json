    "lru-cache": "^11.0.0",
    "marked": "^15.0.0",
    "modifiers-napi": "*",
    "p-map": "^7.0.0",
    "picomatch": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.31.0",
    "semver": "^7.6.0",
    "sharp": "*",
    "shell-quote": "^1.8.0",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.0.0",
    "tree-kill": "^1.2.2",
    "turndown": "^7.1.3",
    "type-fest": "^4.30.0",
    "undici": "^7.0.0",
    "usehooks-ts": "^3.1.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.0",
    "vscode-languageserver-types": "^3.17.0",
    "wrap-ansi": "^9.0.0",
    "ws": "^8.18.0",
