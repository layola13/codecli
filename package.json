    "@opentelemetry/semantic-conventions": "*",
    "ajv": "^8.17.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.0",
    "chalk": "^5.3.0",
