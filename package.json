{
  "name": "claudecode",
  "version": "2.1.88+local.4",
  "description": "Use Claude, Anthropic's AI assistant, right from your terminal. Claude can understand your codebase, edit files, run terminal commands, and handle entire workflows for you.",
  "author": "Anthropic <support@anthropic.com>",
  "license": "SEE LICENSE IN README.md",
  "homepage": "https://github.com/anthropics/claude-code",
  "bugs": {
    "url": "https://github.com/anthropics/claude-code/issues"
  },
  "type": "module",
  "bin": {
    "claudecode": "cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "bash scripts/postinstall.sh",
    "prepare": "node -e \"if (!process.env.AUTHORIZED) { console.error('ERROR: Direct publishing is not allowed.\\nPlease see the release workflow documentation to publish this package.'); process.exit(1); }\"",
    "build:command-bundle": "bun build src/commands/index/cliBundleEntry.ts --target=node --format=esm --outfile src/commands/index/cliBundle.mjs",
    "patch:cli-sidecar": "node scripts/patch-cli-sidecar.mjs",
    "build:index-bundle": "bun run build:command-bundle",
    "build:bun": "bun scripts/bun-build.mjs --source",
    "build:bun:preview": "bun run typecheck:preview && bun scripts/bun-build.mjs --source --preview",
    "compile:bun": "bun scripts/bun-build.mjs --compile --source",
    "compile:bun:preview": "bun run typecheck:preview && bun scripts/bun-build.mjs --compile --source --preview",
    "build:bun:published": "bun run build:command-bundle && bun run patch:cli-sidecar && bun scripts/bun-build.mjs --published",
    "compile:bun:published": "bun run build:command-bundle && bun run patch:cli-sidecar && bun scripts/bun-build.mjs --compile --published",
    "install:local": "mkdir -p ~/.local/bin && cp dist/claudecode ~/.local/bin/claudecode.tmp && chmod 755 ~/.local/bin/claudecode.tmp && mv ~/.local/bin/claudecode.tmp ~/.local/bin/claudecode",
    "install:local:preview": "mkdir -p ~/.local/bin && cp dist/claudenative ~/.local/bin/claudenative.tmp && chmod 755 ~/.local/bin/claudenative.tmp && mv ~/.local/bin/claudenative.tmp ~/.local/bin/claudenative",
    "rebuild:local": "bun run compile:bun && bun run install:local",
    "rebuild:local:preview": "bun run compile:bun:preview && bun run install:local:preview",
    "verify:preview": "bun run typecheck:preview && bun scripts/verify-preview-build.mjs",
    "smoke:preview": "bun scripts/smoke-preview-build.mjs",
    "index": "bun run build:index-bundle && node src/commands/index/cliBundle.mjs",
    "index:status": "cat .code_index/index/manifest.json 2>/dev/null || echo 'No index found. Run /index first.'",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:preview": "bunx tsc --noEmit -p tsconfig.preview-check.json",
    "buildandinstall": "bun run compile:bun && bun run install:local",
    "buildandinstall:preview": "bun run compile:bun:preview && bun run install:local:preview"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "@anthropic-ai/bedrock-sdk": "*",
    "@anthropic-ai/foundry-sdk": "*",
    "@anthropic-ai/mcpb": "*",
    "@anthropic-ai/sandbox-runtime": "*",
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "*",
    "@xmldom/xmldom": "^0.8.11",
    "@aws-sdk/client-bedrock": "*",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-sts": "*",
    "@azure/identity": "*",
    "@commander-js/extra-typings": "^13.0.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "*",
    "@opentelemetry/exporter-logs-otlp-grpc": "*",
    "@opentelemetry/exporter-logs-otlp-http": "*",
    "@opentelemetry/exporter-logs-otlp-proto": "*",
    "@opentelemetry/exporter-metrics-otlp-grpc": "*",
    "@opentelemetry/exporter-metrics-otlp-http": "*",
    "@opentelemetry/exporter-metrics-otlp-proto": "*",
    "@opentelemetry/exporter-prometheus": "*",
    "@opentelemetry/exporter-trace-otlp-grpc": "*",
    "@opentelemetry/exporter-trace-otlp-http": "*",
    "@opentelemetry/exporter-trace-otlp-proto": "*",
    "@opentelemetry/resources": "*",
    "@opentelemetry/sdk-logs": "*",
